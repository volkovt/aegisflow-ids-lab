# Arquivo gerado automaticamente — NÃO editar manualmente (edite config.yaml)
Vagrant.configure("2") do |config|
  config.vm.box_check_update = true
  # Evita regenerar chaves e mudanças desnecessárias no SSH
  config.ssh.insert_key = false

  # Escopo global do provider (mantém GUI off)
  config.vm.provider "{{ provider }}" do |vb|
    vb.gui = false
  end

  # Desativa o /vagrant padrão (usaremos apenas os synced_folders declarados por VM)
  config.vm.synced_folder ".", "/vagrant", disabled: true

  {% for m in machines %}
  config.vm.define "{{ m.name }}" do |{{ m.name }}|
    {{ m.name }}.vm.box = "{{ m.box }}"
    {{ m.name }}.vm.hostname = "{{ m.hostname }}"

    # Recursos por VM
    {{ m.name }}.vm.provider "{{ provider }}" do |vb|
      vb.memory = {{ m.memory }}
      vb.cpus   = {{ m.cpus }}

      # Garante que a NIC2 (host-only) aceite quadros de todos (sensor precisa disso).
      # Se quiser limitar, defina m.promisc=false no contexto.
      {% if m.promisc is defined %}
      vb.customize ["modifyvm", :id, "--nicpromisc2", "{{ 'allow-all' if m.promisc else 'deny' }}"]
      {% else %}
      vb.customize ["modifyvm", :id, "--nicpromisc2", "{{ 'allow-all' if (m.role|default('') == 'sensor') else 'allow-all' }}"]
      {% endif %}

      # Evita "cabo desconectado" na NIC2 em alguns hosts
      vb.customize ["modifyvm", :id, "--cableconnected2", "on"]
    end

    # Network:
    # - NIC1 (default) = NAT (internet) — Vagrant cria por padrão.
    # - NIC2 = Host-Only na sub-rede ip_base (ex.: 192.168.56.X)
    #   -> essencial para attacker/victim/sensor se verem e para o Zeek capturar.
    {{ m.name }}.vm.network "private_network",
      ip: "{{ ip_base }}{{ m.ip_last_octet }}"

    {% if m.synced_folders %}
    {% for sf in m.synced_folders %}
    {{ m.name }}.vm.synced_folder "{{ sf.host }}", "{{ sf.guest }}", create: true
    {% endfor %}
    {% endif %}

    {% if m.provision %}
    {% for p in m.provision %}
    {{ m.name }}.vm.provision "shell", inline: <<-SHELL
{{ p.inline | indent(width=6) }}
    SHELL
    {% endfor %}
    {% endif %}
  end
  {% endfor %}
end
